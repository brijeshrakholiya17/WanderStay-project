<% layout("/layouts/boilerplate") %>

<!-- MapLibre GL JS Assets -->
<link rel="stylesheet" href="/vendor/maplibre-gl/maplibre-gl.css">
<script src="/vendor/maplibre-gl/maplibre-gl.js"></script>

<!-- Custom Styling -->
<link rel="stylesheet" href="/css/wanderstay-map.css">

<div class="map-page-container">
    
    <!-- Controls Bar -->
    <div class="map-controls-bar">
        <div class="search-box-wrapper">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="mapSearchInput" placeholder="Search by title, location, category, country...">
        </div>
        
        <div class="d-flex align-items-center gap-3 justify-content-between flex-wrap">
            <span class="result-count-badge" id="mapResultCount">Showing 0 stays</span>
            
            <div class="view-toggle-group">
                <button class="toggle-btn active" id="toggleMapViewBtn">
                    <i class="fa-solid fa-map"></i> Map View
                </button>
                <button class="toggle-btn" id="toggleListViewBtn">
                    <i class="fa-solid fa-list"></i> List View
                </button>
            </div>
        </div>
    </div>
    
    <!-- Map View Container -->
    <div class="map-view-container" id="mapViewContainer">
        <!-- Sidebar Panel -->
        <div class="map-sidebar" id="mapSidebar">
            <!-- Sidebar cards will be dynamically generated by JS -->
        </div>
        
        <!-- Map Canvas Container -->
        <div class="map-canvas-container">
            <div id="mapCanvas" class="map-canvas"></div>
        </div>
    </div>
    
    <!-- List View Container -->
    <div class="list-view-container" id="listViewContainer">
        <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-2 row-cols-1 g-4" id="listViewRow">
            <!-- Grid cards will be dynamically generated by JS -->
        </div>
    </div>
    
    <!-- Dynamic Empty State -->
    <div class="map-empty-state d-none" id="mapEmptyState">
        <i class="fa-solid fa-magnifying-glass-location"></i>
        <h5>No matches found</h5>
        <p class="text-muted m-0">Try checking your spelling or adjusting your keywords.</p>
    </div>
    
</div>

<!-- Safely serialize listings -->
<script>
    window.WANDERSTAY_MAP_LISTINGS = <%- JSON.stringify(mapListings || []) %>;
</script>

<!-- Map controller script -->
<script src="/js/wanderstay-map.js"></script>
