<% layout("/layouts/boilerplate") %>

<style>
    body {
        background-color: #FAF9F6 !important;
        font-family: "Plus Jakarta Sans", sans-serif;
    }

    /* --- Page Layout --- */
    .edit-page-container {
        max-width: 1100px;
        margin: 3rem auto 5rem auto;
        padding: 0 1.5rem;
    }

    .page-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #222;
        margin-bottom: 2rem;
        letter-spacing: -0.5px;
    }

    /* --- Split Grid Layout --- */
    .layout-grid {
        display: grid;
        grid-template-columns: 1fr 2.2fr;
        gap: 3rem; /* Reduced gap slightly for better flow on mid-sized screens */
    }

    /* --- Left Side: Host Tips Sidebar --- */
    .tips-sidebar {
        position: sticky;
        top: 6.5rem;
        height: fit-content;
    }
    
    .tip-box {
        background-color: #ffffff;
        border-radius: 1.2rem;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid #ebebeb;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .tip-box i {
        font-size: 1.8rem;
        color: #fe424d;
        margin-bottom: 1rem;
    }

    .tip-box h5 {
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
        color: #222;
    }

    .tip-box p {
        font-size: 0.9rem;
        color: #717171;
        margin: 0;
        line-height: 1.6;
    }

    /* --- Right Side: The Form Card --- */
    .form-section {
        background: #ffffff;
        border: 1px solid #ebebeb;
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 12px 35px rgba(0,0,0,0.04);
    }

    .form-section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #222;
        margin-bottom: 2rem;
    }

    /* --- Premium Floating Labels --- */
    .form-floating > .form-control,
    .form-floating > .form-select {
        border: 1px solid #b0b0b0;
        border-radius: 12px;
        padding: 1rem 1.2rem;
        height: 60px;
        font-size: 1rem;
        color: #222;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

    .form-floating > label {
        padding: 1rem 1.2rem;
        color: #717171;
        font-weight: 500;
    }

    .form-control:focus, .form-select:focus {
        border-color: #222;
        border-width: 2px;
        padding: calc(1rem - 1px) calc(1.2rem - 1px);
    }

    .form-floating > textarea.form-control {
        height: 150px;
        padding-top: 1.5rem;
        resize: vertical;
    }

    /* --- Image Upload & Preview --- */
    .image-preview-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: #f8f9fa;
        border: 1px solid #ebebeb;
        padding: 1.2rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
    }

    .preview-img {
        width: 100px;
        height: 75px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    }

    .upload-zone {
        border: 2px dashed #b0b0b0;
        border-radius: 12px;
        padding: 2.5rem 1rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s ease;
        background-color: #fff;
        position: relative;
    }

    .upload-zone:hover {
        border-color: #222;
        background-color: #fcfcfc;
    }

    .upload-zone i {
        font-size: 2.5rem;
        color: #222;
        margin-bottom: 1rem;
    }

    .upload-zone h6 {
        font-weight: 600;
        margin-bottom: 0.2rem;
    }

    .upload-zone input[type="file"] {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
        z-index: 10; /* Ensures the input stays clickable on top of the preview */
    }

    #imagePreview {
        max-width: 100%;
        max-height: 200px;
        border-radius: 8px;
        object-fit: cover;
        display: none;
        margin: 0 auto;
        position: relative;
        z-index: 1; /* Sits underneath the invisible file input */
    }

    /* --- Price Input Group --- */
    .price-group {
        display: flex;
        align-items: center;
    }
    
    .price-symbol {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 60px;
        background-color: #fff;
        border: 1px solid #b0b0b0;
        border-right: none;
        border-radius: 12px 0 0 12px;
        font-size: 1.2rem;
        color: #222;
    }

    .price-input-floating {
        flex-grow: 1;
    }

    .price-input-floating .form-control {
        border-radius: 0 12px 12px 0;
    }

    /* --- Buttons --- */
    .btn-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #ebebeb;
    }

    .btn-cancel {
        color: #222;
        font-weight: 600;
        text-decoration: underline;
        padding: 0.5rem;
        transition: color 0.2s ease;
    }

    .btn-cancel:hover {
        color: #fe424d;
    }

    .btn-save {
        background-color: #fe424d;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        padding: 0.9rem 2.5rem;
        border-radius: 10px;
        border: none;
        transition: all 0.2s ease;
    }

    .btn-save:hover {
        background-color: #d9353f;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(254, 66, 77, 0.2);
    }

    /* =========================================
       100% RESPONSIVE MEDIA QUERIES 
       ========================================= */
       
    /* Tablet / Small Desktop */
    @media (max-width: 991px) {
        .layout-grid {
            grid-template-columns: 1fr; /* Stacks the sidebar and form */
            gap: 1.5rem;
        }
        .tips-sidebar {
            position: relative;
            top: 0;
            display: flex;
            gap: 1rem;
            overflow-x: auto;
            scrollbar-width: none; /* Hide scrollbar for cleaner look */
            padding-bottom: 0.5rem;
        }
        .tip-box {
            min-width: 260px; /* Allows cards to scroll horizontally */
            margin-bottom: 0;
        }
        .tips-sidebar::-webkit-scrollbar {
            display: none;
        }
    }

    /* Mobile Phones */
    @media (max-width: 768px) {
        .edit-page-container {
            padding: 0 1rem;
            margin-top: 2rem;
        }
        .page-title {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
        }
        .form-section {
            padding: 1.5rem; /* Reclaim horizontal space inside the form */
            border-radius: 1rem;
        }
        .image-preview-card {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
        .btn-actions {
            flex-direction: column-reverse; /* Stacks Cancel below Save */
            gap: 1.2rem;
            margin-top: 2rem;
        }
        .btn-save {
            width: 100%; /* Full width button on mobile */
        }
        .btn-cancel {
            text-decoration: none; /* Cleaner look on mobile */
            text-align: center;
            width: 100%;
        }
    }

    /* Extra Small Phones (e.g. iPhone SE) */
    @media (max-width: 480px) {
        .page-title {
            font-size: 1.5rem;
        }
        .form-section-title {
            font-size: 1.2rem;
        }
        .tip-box {
            min-width: 240px;
            padding: 1.2rem;
        }
    }
</style>

<div class="edit-page-container">
    
    <h1 class="page-title">Edit your listing</h1>

    <div class="layout-grid">
        
        <div class="tips-sidebar">
            <div class="tip-box">
                <i class="fa-solid fa-pen-nib"></i>
                <h5>Catchy Titles</h5>
                <p>Properties with unique, descriptive titles stand out more in search results.</p>
            </div>
            <div class="tip-box">
                <i class="fa-regular fa-image"></i>
                <h5>High-Quality Photos</h5>
                <p>Your cover photo is your first impression. Make sure it's bright and welcoming!</p>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Property Details</h3>
            
            <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
                
                <div class="form-floating mb-4">
                    <!-- Changed name="listing[title]" to name="title" -->
                    <input type="text" name="title" value="<%= listing.title %>" class="form-control" id="title" placeholder="Property Title" required>
                    <label for="title">Property Title</label>
                    <div class="invalid-feedback px-2">Please enter a valid title.</div>
                </div>

                <div class="form-floating mb-4">
                    <!-- Changed name="listing[description]" to name="description" -->
                    <textarea name="description" class="form-control" id="description" placeholder="Description" required><%= listing.description %></textarea>
                    <label for="description">Property Description</label>
                    <div class="invalid-feedback px-2">Please provide a short description.</div>
                </div>

                <div class="image-preview-card">
                    <img src="<%= listing.image.url %>" alt="Current Image" class="preview-img">
                    <div>
                        <h6 class="m-0 fw-bold">Current Cover Image</h6>
                        <p class="text-muted m-0" style="font-size: 0.85rem;">This is currently visible to guests.</p>
                    </div>
                </div>

                <div class="upload-zone mb-4" id="uploadZone">
                    <div id="uploadContent">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                        <h6>Drag your new image here</h6>
                        <p class="text-muted m-0" style="font-size: 0.85rem;">Or click to browse your files. Leave blank to keep current image.</p>
                    </div>

                    <img id="imagePreview" src="" alt="New Image Preview">

                    <!-- Changed name="listing[image]" to name="image" -->
                    <input type="file" name="image" id="image" accept="image/*">
                    <div class="invalid-feedback d-block mt-2" style="display: none;">Please select a valid image file.</div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="price-group">
                            <div class="price-symbol"><i class="fa-solid fa-indian-rupee-sign"></i></div>
                            <div class="form-floating price-input-floating">
                                <!-- Changed name="listing[price]" to name="price" -->
                                <input type="number" name="price" value="<%= listing.price %>" class="form-control" id="price" placeholder="Price" required>
                                <label for="price">Price per night</label>
                                <div class="invalid-feedback px-2">Price should be valid</div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                            <small class="text-muted" style="font-size: 0.75rem;">Not sure what to charge?</small>
                            <button type="button" class="btn btn-sm btn-outline-dark py-1 px-2 border-secondary-subtle" id="btn-ai-suggest" style="border-radius: 8px; font-weight: 600; font-size: 0.75rem;">
                                <i class="fa-solid fa-wand-magic-sparkles" style="color: #fe424d; margin-right: 4px;"></i> Get AI Price Suggestion
                            </button>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <!-- Changed name="listing[category]" to name="category" -->
                            <select name="category" class="form-select" id="category" required>
                                <option value="Trending" <%= listing.category === 'Trending' ? 'selected' : '' %>>Trending</option>
                                <option value="Room" <%= listing.category === 'Room' ? 'selected' : '' %>>Room</option>
                                <option value="Beach" <%= listing.category === 'Beach' ? 'selected' : '' %>>Beach</option>
                                <option value="Arctic" <%= listing.category === 'Arctic' ? 'selected' : '' %>>Arctic</option>
                                <option value="Castle" <%= listing.category === 'Castle' ? 'selected' : '' %>>Castle</option>
                                <option value="Amazing pools" <%= listing.category === 'Amazing pools' ? 'selected' : '' %>>Amazing pools</option>
                                <option value="Vineyard" <%= listing.category === 'Vineyard' ? 'selected' : '' %>>Vineyard</option>
                                <option value="Boats" <%= listing.category === 'Boats' ? 'selected' : '' %>>Boats</option>
                                <option value="Mountains" <%= listing.category === 'Mountains' ? 'selected' : '' %>>Mountains</option>
                                <option value="Top cities" <%= listing.category === 'Top cities' ? 'selected' : '' %>>Top cities</option>
                                <option value="Bed & Breakfasts" <%= listing.category === 'Bed & Breakfasts' ? 'selected' : '' %>>Bed & Breakfasts</option>
                                <option value="Golfing" <%= listing.category === 'Golfing' ? 'selected' : '' %>>Golfing</option>
                                <option value="Creative spaces" <%= listing.category === 'Creative spaces' ? 'selected' : '' %>>Creative spaces</option>
                                <option value="Towers" <%= listing.category === 'Towers' ? 'selected' : '' %>>Towers</option>
                            </select>
                            <label for="category">Category</label>
                            <div class="invalid-feedback px-2">Please select a category</div>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mb-2">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <!-- Changed name="listing[location]" to name="location" -->
                            <input type="text" name="location" value="<%= listing.location %>" class="form-control" id="location" placeholder="Location" required>
                            <label for="location">City / Location</label>
                            <div class="invalid-feedback px-2">Location should be valid</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <!-- Changed name="listing[country]" to name="country" -->
                            <input type="text" name="country" value="<%= listing.country %>" class="form-control" id="country" placeholder="Country" required>
                            <label for="country">Country</label>
                            <div class="invalid-feedback px-2">Country name should be valid</div>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-4">
                    <input type="text" name="address" value="<%= listing.address || '' %>" class="form-control" id="address" placeholder="Address" required>
                    <label for="address">Exact Address</label>
                    <div class="invalid-feedback px-2">Please enter the exact address for mapping.</div>
                </div>

                <!-- Map Location Picker (Optional) -->
                <div class="mb-4">
                    <label class="form-label fw-bold mb-1"><i class="fa-solid fa-map-location-dot text-danger me-2"></i>Pin Location on Map (Optional)</label>
                    <p class="text-muted mb-2" style="font-size: 0.85rem; line-height: 1.4;">
                        Search or type the address, city, and country above, and the map will center on that area. Then, click directly on the map to pin the exact location of your property. If left unpinned, we will automatically locate it.
                    </p>
                    
                    <!-- Hidden inputs for manual coordinates -->
                    <input type="hidden" name="latitude" id="latInput" value="<%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[1] : '' %>">
                    <input type="hidden" name="longitude" id="lngInput" value="<%= listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates[0] : '' %>">

                    <!-- Map Libre Assets -->
                    <link rel="stylesheet" href="/vendor/maplibre-gl/maplibre-gl.css">
                    <script src="/vendor/maplibre-gl/maplibre-gl.js"></script>

                    <div class="position-relative overflow-hidden" style="border: 1px solid #b0b0b0; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                        <div id="manualMapPicker" style="width: 100%; height: 320px; background-color: #fafafa;"></div>
                        
                        <!-- Pinned coordinate badge -->
                        <div id="pickerCoordBadge" class="position-absolute bottom-0 start-0 m-3 p-2 bg-white rounded shadow-sm d-none" style="z-index: 10; font-size: 0.8rem; border: 1px solid #ebebeb; display: flex; align-items: center; gap: 8px;">
                            <span class="fw-bold text-dark"><i class="fa-solid fa-location-dot text-danger"></i> Pinned:</span> 
                            <span id="pickerCoordText" class="text-muted"></span>
                            <button type="button" id="clearPinBtn" class="btn btn-sm btn-link text-danger p-0 ms-2 fw-bold text-decoration-none" style="font-size: 0.8rem;">Clear Pin</button>
                        </div>
                    </div>
                </div>

                <div class="btn-actions">
                    <a href="/listings/<%= listing._id %>" class="btn-cancel">Cancel editing</a>
                    <button type="submit" class="btn-save">Save Changes</button>
                </div>

            </form>
        </div>
    </div>
</div>

<%- include("../includes/aiModal.ejs") %>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const imageInput = document.getElementById('image');
        const imagePreview = document.getElementById('imagePreview');
        const uploadContent = document.getElementById('uploadContent');

        imageInput.addEventListener('change', function(event) {
            const file = event.target.files[0];
            
            if (file) {
                // Ensure it's an image
                if (!file.type.startsWith('image/')) {
                    const feedback = document.querySelector('#uploadZone .invalid-feedback');
                    if (feedback) {
                        feedback.textContent = 'Please select a valid image file.';
                        feedback.style.display = 'block';
                    }
                    imageInput.value = ''; // Clear the input
                    imagePreview.src = "";
                    imagePreview.style.display = 'none';
                    uploadContent.style.display = 'block';
                    return;
                } else {
                    const feedback = document.querySelector('#uploadZone .invalid-feedback');
                    if (feedback) {
                        feedback.style.display = 'none';
                    }
                }

                // Read and display the image
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    imagePreview.style.display = 'block';
                    uploadContent.style.display = 'none'; // Hide the default text/icon
                }
                reader.readAsDataURL(file);
            } else {
                // Reset if user cancels file selection
                imagePreview.src = "";
                imagePreview.style.display = 'none';
                uploadContent.style.display = 'block';
            }
        });

        // Initialize Map Picker with pre-existing coordinates if any
        if (document.getElementById("manualMapPicker")) {
            const existingGeom = <%- (listing.geometry && listing.geometry.coordinates) ? JSON.stringify(listing.geometry) : 'null' %>;
            const hasExisting = existingGeom && existingGeom.coordinates && existingGeom.coordinates.length === 2;

            const defaultCenter = [78.9629, 20.5937];
            const center = hasExisting ? existingGeom.coordinates : defaultCenter;
            const zoom = hasExisting ? 14 : 4;

            const pickerMap = new maplibregl.Map({
                container: "manualMapPicker",
                style: "https://tiles.openfreemap.org/styles/liberty",
                center: center,
                zoom: zoom
            });

            pickerMap.addControl(new maplibregl.NavigationControl(), 'top-right');

            let pickerMarker = null;
            const latInput = document.getElementById("latInput");
            const lngInput = document.getElementById("lngInput");
            const coordBadge = document.getElementById("pickerCoordBadge");
            const coordText = document.getElementById("pickerCoordText");
            const clearPinBtn = document.getElementById("clearPinBtn");

            // Setup initial marker if geometry exists
            if (hasExisting) {
                const lng = existingGeom.coordinates[0];
                const lat = existingGeom.coordinates[1];
                pickerMarker = new maplibregl.Marker({ color: "#fe424d" })
                    .setLngLat([lng, lat])
                    .addTo(pickerMap);
                coordText.textContent = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                coordBadge.classList.remove("d-none");
            }

            // Click map to pin location
            pickerMap.on("click", function (e) {
                const lng = e.lngLat.lng;
                const lat = e.lngLat.lat;

                latInput.value = lat;
                lngInput.value = lng;

                if (pickerMarker) {
                    pickerMarker.setLngLat([lng, lat]);
                } else {
                    pickerMarker = new maplibregl.Marker({ color: "#fe424d" })
                        .setLngLat([lng, lat])
                        .addTo(pickerMap);
                }

                coordText.textContent = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                coordBadge.classList.remove("d-none");
            });

            // Clear pinned location
            clearPinBtn.addEventListener("click", function () {
                latInput.value = "";
                lngInput.value = "";
                if (pickerMarker) {
                    pickerMarker.remove();
                    pickerMarker = null;
                }
                coordBadge.classList.add("d-none");
            });

            // Auto fly map to area when user edits address components
            const addressInput = document.getElementById("address");
            const locationInput = document.getElementById("location");
            const countryInput = document.getElementById("country");

            const flyToSearchedArea = async () => {
                const address = addressInput.value.trim();
                const location = locationInput.value.trim();
                const country = countryInput.value.trim();

                const components = [];
                if (address) components.push(address);
                if (location) components.push(location);
                if (country) components.push(country);

                if (components.length === 0) return;

                const queryStr = components.join(", ");
                try {
                    const response = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(queryStr)}&format=json&limit=1`);
                    if (response.ok) {
                        const data = await response.json();
                        if (data && data.length > 0) {
                            const lon = parseFloat(data[0].lon);
                            const lat = parseFloat(data[0].lat);
                            pickerMap.flyTo({
                                center: [lon, lat],
                                zoom: 14,
                                essential: true
                            });
                        }
                    }
                } catch (err) {
                    console.error("Manual picker geocoding fly failed:", err);
                }
            };

            // Trigger when fields lose focus or change
            addressInput.addEventListener("change", flyToSearchedArea);
            locationInput.addEventListener("change", flyToSearchedArea);
            countryInput.addEventListener("change", flyToSearchedArea);
        }
    });
</script>