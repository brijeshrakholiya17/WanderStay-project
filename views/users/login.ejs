<% layout("/layouts/boilerplate") %>

<style>
    body {
        background-color: #FAF9F6 !important;
        font-family: "Plus Jakarta Sans", sans-serif;
    }

    /* --- Centered Page Layout --- */
    .auth-page-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 150px); /* Accounts for navbar/footer */
        padding: 2rem 1rem;
    }

    /* --- Premium Auth Card --- */
    .auth-card {
        background: #ffffff;
        border: 1px solid #ebebeb;
        border-radius: 1.5rem;
        padding: 2.5rem;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 12px 35px rgba(0,0,0,0.04);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-logo i {
        color: #fe424d;
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .auth-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #222;
        margin-bottom: 0.3rem;
    }

    .auth-subtitle {
        color: #717171;
        font-size: 0.95rem;
    }

    /* --- Floating Labels --- */
    .form-floating {
        margin-bottom: 1.2rem;
        position: relative;
    }

    .form-floating > .form-control {
        border: 1px solid #b0b0b0;
        border-radius: 12px;
        padding: 1rem 1.2rem;
        height: 60px;
        font-size: 1rem;
        color: #222;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

    .form-floating > label {
        padding: 1rem 1.2rem;
        color: #717171;
        font-weight: 500;
    }

    .form-control:focus {
        border-color: #222;
        border-width: 2px;
        padding: calc(1rem - 1px) calc(1.2rem - 1px);
    }

    /* Password Toggle Icon */
    .password-toggle {
        position: absolute;
        top: 50%;
        right: 1rem;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #717171;
        cursor: pointer;
        z-index: 10;
        padding: 0 0.5rem;
        font-size: 1.1rem;
    }
    
    .password-toggle:focus {
        outline: none;
    }

    /* --- Submit Button --- */
    .btn-auth {
        width: 100%;
        background-color: #fe424d;
        color: #fff;
        font-weight: 600;
        font-size: 1.05rem;
        padding: 1rem;
        border-radius: 12px;
        border: none;
        transition: all 0.2s ease;
        margin-top: 0.5rem;
    }

    .btn-auth:hover {
        background-color: #d9353f;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(254, 66, 77, 0.2);
    }

    /* --- Divider --- */
    .auth-divider {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.8rem 0;
        color: #717171;
        font-size: 0.85rem;
    }

    .auth-divider::before,
    .auth-divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #ebebeb;
    }

    .auth-divider:not(:empty)::before { margin-right: .5em; }
    .auth-divider:not(:empty)::after { margin-left: .5em; }

    /* --- Social Auth Buttons --- */
    .btn-social {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        background-color: #fff;
        border: 1px solid #222;
        color: #222;
        font-weight: 600;
        padding: 0.8rem;
        border-radius: 12px;
        margin-bottom: 1rem;
        text-decoration: none;
        transition: background-color 0.2s ease;
    }

    .btn-social:hover {
        background-color: #f8f9fa;
        color: #222;
    }

    /* --- Footer Link --- */
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.95rem;
        color: #222;
    }

    .auth-footer a {
        color: #222;
        font-weight: 700;
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: color 0.2s ease;
    }

    .auth-footer a:hover {
        color: #fe424d;
    }

    /* --- Mobile Responsiveness --- */
    @media (max-width: 576px) {
        .auth-card {
            padding: 2rem 1.5rem;
            border-radius: 1.2rem;
        }
        .auth-title {
            font-size: 1.4rem;
        }
        .btn-auth {
            padding: 0.9rem;
        }
    }
</style>

<div class="auth-page-wrapper">
    <div class="auth-card">
        
        <div class="auth-header">
            <div class="auth-logo">
                <i class="fa-regular fa-compass"></i>
            </div>
            <h1 class="auth-title">Welcome back</h1>
            <p class="auth-subtitle">Log in to your Wanderlust account.</p>
        </div>

        <form method="post" action="/login" class="needs-validation" novalidate>
            
            <div class="form-floating">
                <input type="text" name="username" class="form-control" id="username" placeholder="Username" required>
                <label for="username">Username</label>
                <div class="invalid-feedback px-2">Please enter your username.</div>
            </div>

            <div class="form-floating">
                <input type="password" name="password" class="form-control" id="password" placeholder="Password" required>
                <label for="password">Password</label>
                <button type="button" class="password-toggle" id="togglePassword" tabindex="-1" aria-label="Toggle password visibility">
                    <i class="fa-regular fa-eye" id="eyeIcon"></i>
                </button>
                <div class="invalid-feedback px-2">Please enter your password.</div>
            </div>

            <button type="submit" class="btn-auth mt-3">Log in</button>

        </form>

        <div class="auth-divider">or continue with</div>

        <a href="#" class="btn-social">
            <i class="fa-brands fa-google text-danger"></i> Google
        </a>
        <a href="#" class="btn-social">
            <i class="fa-brands fa-apple fs-5"></i> Apple
        </a>

        <div class="auth-footer">
            Don't have an account? <a href="/signup">Sign up</a>
        </div>

    </div>
</div>

<script>
    // Password visibility toggle logic
    document.addEventListener("DOMContentLoaded", function() {
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("password");
        const eyeIcon = document.getElementById("eyeIcon");

        togglePassword.addEventListener("click", function() {
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);
            
            if (type === "password") {
                eyeIcon.classList.remove("fa-eye-slash");
                eyeIcon.classList.add("fa-eye");
            } else {
                eyeIcon.classList.remove("fa-eye");
                eyeIcon.classList.add("fa-eye-slash");
            }
        });
    });
</script>